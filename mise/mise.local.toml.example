# mise.local.toml.example
#
# Copy to mise.local.toml (never commit — add to .gitignore) to enable
# machine-specific build optimizations on a Linux workstation.
#
# mise merges this file with mise.toml, with local values taking precedence.

[tools]
mold = "latest" # High-speed linker — Linux only (C++)

# Embedded/EE machines only:
# arduino-cli = "latest"            # Command-line Arduino toolchain (Go)
# "gcc-arm-none-eabi" = "latest"    # ARM Cortex-M cross-compiler (C)
# "cargo:cargo-binutils" = "latest" # Binary management for MCUs (Rust)
# "cargo:cargo-bloat" = "latest"    # Analyze binary size overhead (Rust)
# "cargo:probe-rs-tools" = "latest" # MCU flashing/debugging suite (Rust)
# "pipx:platformio" = "latest"      # Embedded framework & build system (Python)
